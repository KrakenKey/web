      "delete": {
        "operationId": "TlsController_remove",
        "summary": "Delete a failed or revoked certificate",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "Certificate ID",
            "schema": {
              "type": "string"
            }
          }
        ],
        "tags": [
          "TLS Certificates"
        ],
        "security": [
          {
            "bearer": []
          }
        ],
        "responses": {
          "200": {
            "description": "Certificate deleted"
          },
          "400": {
            "description": "Certificate not in failed or revoked state"
          },
          "404": {
            "description": "Certificate not found"
          }
        }
      }
    },
