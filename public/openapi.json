        "operationId": "AppController_getInfo",
        "summary": "Get API info",
        "description": "Returns the current status and version of the API",
        "responses": {
          "200": {
            "description": ""
          }
        },
        "parameters": [],
        "tags": [
          "Info"
        ]
      }
    },
