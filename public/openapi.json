        ],
        "security": [
          {
            "bearer": []
          }
        ],
        "responses": {
          "200": {
            "description": "Parsed certificate details"
          },
          "400": {
            "description": "Certificate not yet issued"
          },
          "404": {
            "description": "Certificate not found"
          }
