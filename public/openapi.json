  },
  "components": {
    "schemas": {
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "description": "User display name",
            "example": "John Doe",
            "maxLength": 100
          },
          "notificationPreferences": {
            "type": "object",
            "description": "Notification preferences (omitted keys default to enabled)",
            "example": {
              "cert_issued": true,
              "cert_failed": false
            }
          }
        }
      },
      "CreateApiKeyDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "A human-friendly name for this API key",
            "example": "my-ci-key",
            "default": "default"
          },
          "expiresAt": {
            "type": "string",
            "description": "ISO 8601 expiration date (optional, null = never expires)",
            "example": "2027-01-01T00:00:00.000Z"
          }
        }
      },
      "CreateTlsCrtDto": {
        "type": "object",
        "properties": {
          "csrPem": {
            "type": "string",
            "description": "PEM-encoded Certificate Signing Request",
            "example": "-----BEGIN CERTIFICATE REQUEST-----\n...\n-----END CERTIFICATE REQUEST-----"
          }
        },
        "required": [
          "csrPem"
        ]
      },
      "UpdateTlsCrtDto": {
        "type": "object",
        "properties": {
          "csrPem": {
            "type": "string",
            "description": "PEM-encoded Certificate Signing Request",
            "example": "-----BEGIN CERTIFICATE REQUEST-----\n...\n-----END CERTIFICATE REQUEST-----"
          },
          "autoRenew": {
            "type": "boolean",
            "description": "Enable or disable automatic renewal"
          }
        }
      },
      "RevokeTlsCrtDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "number",
            "description": "RFC 5280 revocation reason code: 0=unspecified, 1=keyCompromise, 3=affiliationChanged, 4=superseded, 5=cessationOfOperation",
            "example": 0,
            "minimum": 0,
            "maximum": 10
          }
        }
      },
      "CreateDomainDto": {
        "type": "object",
        "properties": {
          "hostname": {
            "type": "string",
            "description": "Fully qualified domain name",
            "example": "example.com"
          }
        },
        "required": [
          "hostname"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "description": "Unique username",
            "example": "jdoe"
          },
          "email": {
            "type": "string",
            "description": "User email address",
            "example": "jdoe@example.com"
          },
          "groups": {
            "description": "User groups",
            "example": [
              "users"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "JWT access token obtained from the /auth/callback OAuth flow"
      },
      "api-key": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "API key prefixed with \"Bearer \" (e.g., \"Bearer kk_abc123...\")"
      }
    }
  },
  "tags": [
    {
      "name": "Health",
      "description": "API status and health checks"
    },
    {
      "name": "Authentication",
      "description": "OAuth login, user profiles, and API key management"
    },
    {
      "name": "Users",
      "description": "User management"
    },
    {
      "name": "Domains",
      "description": "Domain registration and DNS verification"
    },
    {
      "name": "TLS Certificates",
      "description": "Certificate issuance, renewal, and management"
    }
  ],
  "security": []
}