---
import PageLayout from '../layouts/PageLayout.astro';
import FAQ from '../components/FAQ.astro';
import CTA from '../components/CTA.astro';

const faqItems = [
  {
    question: 'What does KrakenKey do?',
    answer: 'KrakenKey automates TLS certificate lifecycle management — issuance, renewal, monitoring, and revocation. Issue certificates via Let\'s Encrypt in ~4 minutes through the dashboard, REST API, or CLI. Monitor your TLS endpoints from distributed probes to catch expiring certs, broken chains, and misconfigurations before they cause outages.',
  },
  {
    question: 'Why are certificate lifetimes getting shorter?',
    answer: 'The CA/Browser Forum approved Ballot SC-081v3, which phases TLS certificate maximum lifetimes from 398 days down to 47 days by March 2029. Shorter lifetimes reduce the window of exposure if a key is compromised. This makes automation essential.',
  },
  {
    question: 'How does endpoint monitoring work?',
    answer: 'Register any TLS endpoint (host:port) and KrakenKey scans it on a schedule using distributed probes. Each scan performs a real TLS handshake and reports connection health, certificate details, chain validation, and latency. Use our hosted probes for zero-ops monitoring from multiple regions, or run the open-source probe on your own infrastructure for internal services.',
  },
  {
    question: 'How does client-side CSR generation work?',
    answer: 'KrakenKey uses the WebCrypto API built into modern browsers to generate your Certificate Signing Request entirely client-side. Your private key is generated in your browser and never leaves your device. Only the CSR (which contains your public key) is sent to our servers.',
  },
  {
    question: 'Is there a REST API and CLI?',
    answer: 'Yes. Every action available in the dashboard is also available via REST API and the krakenkey CLI. Issue certificates, manage domains, configure endpoint monitoring, and export scan results — all programmatically. AI agent tool definitions are included for automated workflows.',
  },
  {
    question: 'Do I need a paid plan?',
    answer: 'No. The free tier includes ACME automation, certificate issuance, and 3 monitored endpoints with connected probes. Starter ($29/mo) adds 10 endpoints, 2 hosted probe regions, auto-renewal, and expiry alerts. Team ($79/mo) adds 50 endpoints, 5 hosted regions, organizations with RBAC, and 5-minute scan intervals.',
  },
];
---

<PageLayout
  title="Pricing"
  description="Free automated TLS certificate issuance via Let's Encrypt. Starter and Team plans for higher limits, auto-renewal, and team access."
>
  <div class="section-container">
    <div class="section-header section-header--lg">
      <h1 class="section-title section-title--xl">Pricing</h1>
      <p class="section-subtitle">
        Free tier includes full ACME automation. Paid plans add higher limits, auto-renewal, and team access.
      </p>
    </div>

    <!-- Pricing Grid -->
    <div class="pricing-grid pricing-grid--3">
      <!-- Free Tier -->
      <div class="card center-text">
        <h3 class="pricing-label">Free</h3>
        <p class="pricing-sublabel">Full ACME automation, no credit card</p>
        <div class="pricing-price">
          <span>$0</span>
        </div>
        <ul class="pricing-features pricing-features--left">
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            3 domains, 10 active certificates
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            ACME automation via Let's Encrypt
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            In-browser CSR generator
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            DNS-01 challenge via Cloudflare
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            REST API &amp; web dashboard
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            3 monitored endpoints (connected probes)
          </li>
        </ul>
        <p class="pricing-cta-note">No credit card required</p>
        <a href="https://app.krakenkey.io" class="btn btn-primary btn-full">Get Started Free</a>
      </div>

      <!-- Starter Tier -->
      <div class="card card-highlighted center-text">
        <span class="card-badge">Popular</span>
        <h3 class="pricing-label">Starter</h3>
        <p class="pricing-sublabel">More domains, auto-renewal, alerts</p>
        <div class="pricing-price">
          <span>$29</span><span class="pricing-sublabel">/mo</span>
        </div>
        <ul class="pricing-features pricing-features--left">
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            10 domains, 75 active certificates
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            30-day auto-renewal window
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            Certificate expiry notifications
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            Double API rate limits
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            10 endpoints, 2 hosted probe regions
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            Everything in Free
          </li>
        </ul>
        <a href="https://app.krakenkey.io" class="btn btn-primary btn-full">Upgrade to Starter</a>
      </div>

      <!-- Team Tier -->
      <div class="card center-text">
        <h3 class="pricing-label">Team</h3>
        <p class="pricing-sublabel">Multi-user access with role-based control</p>
        <div class="pricing-price">
          <span>$79</span><span class="pricing-sublabel">/mo</span>
        </div>
        <ul class="pricing-features pricing-features--left">
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            25 domains, 375 active certificates
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            Organizations with RBAC
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            Invite team members (owner, admin, member, viewer)
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            Higher rate limits (300 reads/min)
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            50 endpoints, 5 hosted regions, 5-min scans
          </li>
          <li class="pricing-feature">
            <span class="pricing-feature-check">&#10003;</span>
            Everything in Starter
          </li>
        </ul>
        <a href="https://app.krakenkey.io" class="btn btn-primary btn-full">Upgrade to Team</a>
      </div>
    </div>

    <FAQ items={faqItems} />
  </div>

  <CTA />
</PageLayout>
