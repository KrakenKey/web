---
---

<section class="hero-section">
  <div class="section-container hero-grid">
    <div class="hero-content">
      <h1 class="hero-title">
        TLS certificate management, <span class="text-accent">automated.</span>
      </h1>
      <p class="hero-subtitle">
        One-time DNS setup, then TLS certificates in 4 minutes — no ongoing records to manage, no cron jobs, no forgotten renewals.
      </p>
      <div class="hero-actions">
        <a href="https://app.krakenkey.io" class="btn btn-primary btn-lg">Get Started Free</a>
        <a href="/pricing" class="btn btn-outline btn-lg">Learn More</a>
      </div>
      <p class="hero-note">Free to use. No credit card required.</p>
    </div>

    <div class="code-block hero-code">
      <div><span class="code-comment"># Issue a TLS certificate</span></div>
      <div><span class="code-cmd">$</span> <span class="code-string">krakenkey cert issue --domain example.com --wait</span></div>
      <div><span class="code-success">&#10003; CSR generated (private key stays local)</span></div>
      <div><span class="code-success">&#10003; Certificate issued in 3m 42s</span></div>
      <div><span class="code-success">&#10003; Saved to ./example.com.crt</span></div>
      <div class="hero-code-gap"><span class="code-comment"># Monitor your TLS endpoints</span></div>
      <div><span class="code-cmd">$</span> <span class="code-string">krakenkey endpoint add api.example.com:443</span></div>
      <div><span class="code-cmd">$</span> <span class="code-string">krakenkey endpoint scan &lt;endpoint-id&gt;</span></div>
      <div><span class="code-success">&#10003; TLS 1.3 &middot; ECDSA P-256 &middot; chain valid</span></div>
      <div><span class="code-success">&#10003; Expires in 187 days</span></div>
      <div><span class="code-success">&#10003; Latency: 42ms (us-east-1)</span></div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.25rem;
    }
  }
</style>
