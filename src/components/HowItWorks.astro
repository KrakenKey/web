---
const setupSteps = [
  {
    number: '1',
    title: 'Add your domain',
    description: 'Register your domain in the dashboard and add two DNS records: a TXT record to verify ownership and a CNAME to delegate ACME challenges to KrakenKey.',
  },
];

const certSteps = [
  {
    number: '2',
    title: 'Generate CSR in-browser',
    description: 'Use the WebCrypto API to generate your Certificate Signing Request. Your private key never leaves your device.',
  },
  {
    number: '3',
    title: 'Submit via dashboard or API',
    description: 'Upload your CSR through the web dashboard or submit it programmatically via REST API.',
  },
  {
    number: '4',
    title: 'Certificate issued in ~4 min',
    description: 'KrakenKey resolves the ACME DNS-01 challenge automatically. Your certificate is issued and ready to download.',
  },
];
---

<section>
  <div class="section-container">
    <div class="section-header">
      <h2 class="section-title">How it works</h2>
      <p class="section-subtitle">
        One-time domain setup, then certificates on demand.
      </p>
    </div>

    <div style="margin-bottom: 2rem;">
      <p class="phase-label">One-time setup</p>
      <div class="steps-grid steps-grid--single">
        {setupSteps.map((step) => (
          <div class="step-item">
            <div class="step-number">{step.number}</div>
            <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem;">{step.title}</h3>
            <p class="text-muted" style="font-size: 0.9375rem; line-height: 1.6;">{step.description}</p>
          </div>
        ))}
      </div>
    </div>

    <div>
      <p class="phase-label">Per certificate</p>
      <div class="steps-grid">
        {certSteps.map((step) => (
          <div class="step-item">
            <div class="step-number">{step.number}</div>
            <h3 style="font-size: 1.125rem; font-weight: 600; margin-bottom: 0.5rem;">{step.title}</h3>
            <p class="text-muted" style="font-size: 0.9375rem; line-height: 1.6;">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .phase-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .steps-grid--single {
    grid-template-columns: repeat(1, 1fr);
    max-width: 320px;
  }

  .step-item {
    text-align: center;
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: rgba(6, 182, 212, 0.1);
    color: var(--color-accent);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  @media (max-width: 768px) {
    .steps-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .steps-grid--single {
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {
    .steps-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
